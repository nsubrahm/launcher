# Application
MACHINE_ID=m001
MACHINE_DATA_TOPIC=m001_data
MACHINE_ALARMS_TOPIC=m001_alarms
MACHINE_LIMITS_TOPIC=m001_limits
MACHINE_ALERTS_TOPIC=m001_alerts
MACHINE_EVENTS_TOPIC=m001_events
# Quarkus, Kafka
QUARKUS_KAFKA_STREAMS_BOOTSTRAP_SERVERS=broker:9092
# Encryption and decryption
ENCRYPT_ALGO=AES/GCM/NoPadding
SECRET_KEY_ALGO=PBKDF2WithHmacSHA256
TAG_LENGTH_BIT=128
IV_LENGTH_BYTE=12
SALT_LENGTH_BYTE=16
ITERATION_COUNT=32767
KEY_LENGTH=256
# NodeJs
KAFKA_BROKER=broker:9092
# General
TZ="Asia/Kolkata"